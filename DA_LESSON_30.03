-- написать запрос, который выводит название категории и среднюю цену продукта этой категории

select 
	t2.category_name,
	t1.avg_price
from (
	select 
		category_id,
		round(avg(list_price), 2) as avg_price
	from products
	group by category_id
	) as t1
	join product_categories as t2
		on t1.category_id = t2.category_id;

-- написать запрос, который выводит название склада и количество единиц продуктов на этом складе

select 
	t1.warehouse_name,
	t2.qty
from warehouses t1
left join (
	select 
		warehouse_id,
		sum(quantity) as qty
	from  inventories
	group by warehouse_id
) as t2
	on t1.warehouse_id = t2.warehouse_id;

-- доработать запрос и вывести название склада с наибольщим количеством товаров

select 
	t1.warehouse_name,
	t2.qty
from warehouses t1
left join (
	select 
		warehouse_id,
		sum(quantity) as qty
	from  inventories
	group by warehouse_id
) as t2
	on t1.warehouse_id = t2.warehouse_id
	where t2.qty = (
	select 
	max(qty) as maxqty
from (select 
			warehouse_id,
			sum(quantity) as qty
		from  inventories
		group by warehouse_id
		)t1
	);

-- написать запрос, который выводит топ 3 самых загруженных склада

select
	warehouse_name,
	qty
from(
	select 
		t1.warehouse_name,
		t2.qty,
		dense_rank() over (order by qty desc) as num
	from warehouses t1
	left join (
		select 
			warehouse_id,
			sum(quantity) as qty
		from  inventories
		group by warehouse_id
	) as t2
		on t1.warehouse_id = t2.warehouse_id
) as t1
where num <= 3;

-- написать запрос, который выводит айди заказа и сумму этого заказа

select 
	order_id,
	sum(quantity * unit_price) as order_total
from order_items 
group by order_id 

-- создать представление tmp_orders со следующими полями:
-- order_id, customer_id, order_total, order_date, status

create view tmp_orders as
select
	t1.order_id,
	t1.customer_id, 
	t2.order_total,
	t1.order_date,
	t1.status
from  orders as t1
join (
	select 
		order_id,
		sum(quantity * unit_price) as order_total
	from order_items 
	group by order_id 
) as t2
on t1.order_id = t2.order_id;

select * from tmp_orders

-- написать запрос, который оставляет только те заказы, у которых сумма заказа больше суммы следующего заказа у клиента

select
	order_id,
	customer_id, 
	order_total,
	order_date,
	status
from (
	select
		order_id,
		customer_id, 
		order_total,
		order_date,
		status,
		lead(order_total) over(partition by customer_id order by order_date) as lead_order_total
	from tmp_orders
) as t1
where order_total > lead_order_total;
	
	
	
	
